{
  "name": "Greenland Hex",
  "dataColors": [
    "#0e6a14",
    "#6259b5",
    "#5437bd",
    "#f91a7e",
    "#96cd63"
  ],
  "foreground": "#111827",
  "background": "#ffffff",
  "foregroundNeutralSecondary": "#6b7280",
  "backgroundLight": "#bce1be",
  "foregroundNeutralTertiary": "#6b7280",
  "backgroundNeutral": "#e4f4e1",
  "tableAccent": "#0e6a14",
  "maximum": "#5437bd",
  "center": "#6259b5",
  "minimum": "#0e6a14",
  "bad": "#0e6a14",
  "neutral": "#6259b5",
  "good": "#5437bd",
  "textClasses": {
    "callout": {
      "color": "#111827",
      "fontFace": "'Segoe UI', Tahoma, Geneva, Verdana, sans-serif"
    },
    "title": {
      "color": "#111827",
      "fontFace": "'Segoe UI', Tahoma, Geneva, Verdana, sans-serif"
    },
    "header": {
      "color": "#111827",
      "fontFace": "'Segoe UI', Tahoma, Geneva, Verdana, sans-serif"
    },
    "label": {
      "color": "#111827",
      "fontFace": "'Segoe UI', Tahoma, Geneva, Verdana, sans-serif"
    }
  },
  "visualStyles": {
    "*": {
      "*": {
        "background": [
          {
            "color": {
              "solid": {
                "color": "#e4f4e1"
              }
            }
          }
        ],
        "border": [
          {
            "color": {
              "solid": {
                "color": "#e4f4e1"
              }
            },
            "show": true,
            "radius": 8
          }
        ],
        "visualHeader": [
          {
            "background": {
              "solid": {
                "color": "#e4f4e1"
              }
            },
            "border": {
              "solid": {
                "color": "#e4f4e1"
              }
            }
          }
        ]
      }
    },
    "page": {
      "*": {
        "outspace": [
          {
            "color": {
              "solid": {
                "color": "#bce1be"
              }
            }
          }
        ],
        "outspacePane": [
          {
            "backgroundColor": {
              "solid": {
                "color": "#ffffff"
              }
            },
            "foregroundColor": {
              "solid": {
                "color": "#000000"
              }
            }
          }
        ],
        "background": [
          {
            "color": {
              "solid": {
                "color": "#ffffff"
              }
            },
            "transparency": 0
          }
        ],
        "filterCard": [
          {
            "$id": "Applied",
            "backgroundColor": {
              "solid": {
                "color": "#ececec"
              }
            },
            "foregroundColor": {
              "solid": {
                "color": "#000000"
              }
            },
            "transparency": 0
          },
          {
            "$id": "Available",
            "backgroundColor": {
              "solid": {
                "color": "#ffffff"
              }
            },
            "foregroundColor": {
              "solid": {
                "color": "#000000"
              }
            },
            "transparency": 0
          }
        ]
      }
    }
  }
}